  "keyFeatures": [
    "Multi-vendor marketplace with business registration and approval workflow",
    "Product catalog management with categories and images",
    "Shopping cart and order processing with pickup time scheduling",
    "Integrated payment processing via Mercado Pago",
    "Customer ratings and reviews system",
    "Business dashboard with sales analytics and PDF reports",
    "Role-based access control (Admin, Business, Customer)",
    "Real-time order status tracking"
  ],
  "publicApiSurface": [
    "POST /api/register - Register new user account",
    "POST /api/login - Authenticate user",
    "POST /api/solicitud-empresa - Submit business application",
    "GET /api/productos/destacados - Get featured products",
    "GET /api/categorias - List all categories",
    "POST /api/cliente/carrito/agregar/{productoId} - Add product to cart",
    "POST /api/cliente/pedidos - Create new order",
    "GET /api/cliente/mis-pedidos - Get customer orders",
    "POST /api/empresa/productos - Create product (business)",
    "GET /api/empresa/pedidos - Get business orders",
    "PATCH /api/empresa/pedidos/{pedido}/estado - Update order status",
    "GET /api/empresa/dashboard - Get business analytics",
    "GET /api/admin/solicitudes - List business applications (admin)",
    "POST /api/admin/aprobar/{id} - Approve business application",
    "POST /api/webhook/mercadopago - Payment webhook endpoint"
  ]
}
